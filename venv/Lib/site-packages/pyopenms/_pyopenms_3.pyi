       pep_id.setScoreType("XTandem")
       # Add a peptide hit
       hit = oms.PeptideHit()
       hit.setScore(50.5)
       hit.setRank(1)
       hit.setSequence(oms.AASequence.fromString("PEPTIDE"))
       hit.setCharge(2)
       pep_id.insertHit(hit)
